{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "",
    "MongoDB": "",
    "Redis": ""
  },
  "MongoDB": {
    "DatabaseName": "OrderProcessingDb"
  },
  "Cache": {
    "OrderListTtlSeconds": 60
  },
  "BackgroundJob": {
    "IntervalMinutes": 5,
    "PendingOrderMinAgeMinutes": 1
  }
}
