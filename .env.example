# ============================================================
# E-Commerce Order Processing — Environment Variables
# Copy this file to .env and fill in values for local dev.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=order_user
POSTGRES_PASSWORD=order_pass
POSTGRES_DB=order_processing
# Used in appsettings.json ConnectionStrings:PostgreSQL
# Host=localhost;Port=5432;Database=order_processing;Username=order_user;Password=order_pass

# --- MongoDB ---
MONGO_ROOT_USER=mongo_user
MONGO_ROOT_PASSWORD=mongo_pass
# Used in appsettings.json ConnectionStrings:MongoDB
# mongodb://mongo_user:mongo_pass@localhost:27017/order_processing?authSource=admin

# --- Redis ---
REDIS_PASSWORD=redis_pass
# Used in appsettings.json ConnectionStrings:Redis
# localhost:6379,password=redis_pass

# --- React UI (Vite) ---
# Create src/OrderProcessing.UI/.env.local with:
VITE_API_BASE_URL=http://localhost:5000/api/v1

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# --- CORS (production) ---
# Comma-separated list of allowed origins
# CORS_ORIGINS=https://yourdomain.com
