# Normalize line endings to LF on commit, checkout as-is on Windows
* text=auto eol=lf

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.gif binary
*.zip binary
*.dll binary
*.exe binary
